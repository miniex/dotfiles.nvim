#!/bin/sh
# $EDITOR for Neovim's embedded terminals. When nested ($NVIM set), forward
# to the parent via --remote-wait. PATH lookup skips our own dir since this
# wrapper is also named `nvim` and would shadow the real binary.
set -eu

# shellcheck disable=SC1007 # `CDPATH=` is a deliberate env prefix for `cd`
SELF_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REAL_NVIM=""
OLDIFS=$IFS
IFS=:
for d in $PATH; do
    [ -z "$d" ] && continue
    if [ "$d" != "$SELF_DIR" ] && [ -x "$d/nvim" ]; then
        REAL_NVIM="$d/nvim"
        break
    fi
done
IFS=$OLDIFS

if [ -z "$REAL_NVIM" ]; then
    echo "term-bin/nvim: real nvim not found in PATH" >&2
    exit 127
fi

if [ -n "${NVIM:-}" ]; then
    exec "$REAL_NVIM" --server "$NVIM" --remote-wait "$@"
fi
exec "$REAL_NVIM" "$@"
